# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@ep-xxxx.neon.tech/elcartable?sslmode=require"

# App
PORT=3000
NODE_ENV=development
API_PREFIX=api/v1

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Invitation flow (commercial)
INVITATION_CODE_EXPIRES_IN_HOURS=72

# CORS
FRONTEND_URL=http://localhost:5173

# Uploads
UPLOAD_MAX_FILE_SIZE_MB=5

# WhatsApp support (QR code target)
WHATSAPP_SUPPORT_NUMBER=2126xxxxxxxx

# Anonymisation des visiteurs (hash IP) — CHANGER en production
IP_HASH_SALT=change-me-ip-salt
