# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@ep-xxxx.neon.tech/elcartable?sslmode=require"

# App
PORT=3000
NODE_ENV=development
API_PREFIX=api/v1

# JWT
# Générer des secrets forts et DISTINCTS (>= 32 caractères), ex: `openssl rand -hex 32`.
# En production le démarrage échoue si un secret est trop court, identique à l'autre,
# ou laissé à sa valeur d'exemple.
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Invitation flow (commercial)
INVITATION_CODE_EXPIRES_IN_HOURS=72

# CORS
FRONTEND_URL=http://localhost:5173

# Uploads
UPLOAD_MAX_FILE_SIZE_MB=5
# Répertoire disque de fallback (utilisé uniquement si R2 n'est pas configuré)
UPLOAD_DIR=./uploads

# Cloudflare R2 (stockage objet S3-compatible) — images produits, logos écoles,
# avatars utilisateurs, PDF de commandes. Aucun fichier n'est stocké en base :
# seule l'URL publique R2 est persistée dans Neon. Les clés ci-dessous sont
# STRICTEMENT côté serveur et ne doivent jamais être exposées au frontend.
# Si ces variables sont absentes, l'app retombe automatiquement sur le disque
# local (utile en dev sans compte R2).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=elcartable
# Optionnel : par défaut https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=
# URL publique du bucket (r2.dev ou domaine personnalisé), ex: https://cdn.elcartable.ma
R2_PUBLIC_URL=

# WhatsApp support (QR code target)
WHATSAPP_SUPPORT_NUMBER=2126xxxxxxxx

# Anonymisation des visiteurs (hash IP) — REQUIS en production (le démarrage
# échoue s'il est absent ou laissé à une valeur d'exemple).
IP_HASH_SALT=change-me-ip-salt
