# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@ep-xxxx.neon.tech/elcartable?sslmode=require"

# App
PORT=3000
NODE_ENV=development
API_PREFIX=api/v1

# JWT
# Générer des secrets forts et DISTINCTS (>= 32 caractères), ex: `openssl rand -hex 32`.
# En production le démarrage échoue si un secret est trop court, identique à l'autre,
# ou laissé à sa valeur d'exemple.
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Invitation flow (commercial)
INVITATION_CODE_EXPIRES_IN_HOURS=72

# CORS
FRONTEND_URL=http://localhost:5173

# Uploads
UPLOAD_MAX_FILE_SIZE_MB=5

# WhatsApp support (QR code target)
WHATSAPP_SUPPORT_NUMBER=2126xxxxxxxx

# Anonymisation des visiteurs (hash IP) — REQUIS en production (le démarrage
# échoue s'il est absent ou laissé à une valeur d'exemple).
IP_HASH_SALT=change-me-ip-salt
