# Origine du backend Nest utilisée par le proxy Vite en dev.
VITE_BACKEND_ORIGIN=http://localhost:3000

# Base d'API utilisée par le client axios. Par défaut relative (via le proxy
# Vite). En prod, mettre l'URL absolue du backend, ex:
# VITE_API_URL=https://api.elcartable.ma/api/v1/v1
VITE_API_URL=/api/v1/v1
